<%= form_with model: @log,
              html: { class: "log-form js-log-form",
                      data: { existing_images_count: @log.images.size } } do |f| %>

  <% if @log.errors.any? %>
    <div class="rs-form-errors">
      <p class="rs-form-errors__title">
        <%= pluralize(@log.errors.count, "件のエラー") %>があります。
      </p>
      <ul>
        <% @log.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :title, "タイトル" %>
    <%= f.text_field :title, required: true %>
  </div>

  <div class="field"
       data-controller="category-modal"
       data-category-modal-categories-url-value="<%= categories_path %>">
    <%= f.label :category_id, "カテゴリ" %>
    <div class="category-select-row">
      <%= f.collection_select :category_id,
            @categories, :id, :name,
            { include_blank: "カテゴリを選択してください" },
            { data: { category_modal_target: "select" } } %>
      <button type="button" class="btn-add-category"
              data-action="click->category-modal#open">
        ＋ 新規
      </button>
    </div>

    <div class="cat-modal is-hidden" data-category-modal-target="modal">
      <div class="cat-modal__overlay" data-action="click->category-modal#close"></div>
      <div class="cat-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="cat-modal-title"
           data-action="keydown->category-modal#handleKeydown">
        <div class="cat-modal__header">
          <h3 class="cat-modal__title" id="cat-modal-title">新しいカテゴリを追加</h3>
          <button type="button" class="cat-modal__close"
                  data-action="click->category-modal#close">×</button>
        </div>
        <div class="cat-modal__body">
          <p class="cat-modal__error is-hidden" data-category-modal-target="error"></p>
          <div class="rs-form-group">
            <label class="rs-form-label" for="modal_category_name">カテゴリ名</label>
            <input type="text" id="modal_category_name"
                   class="rs-input-text"
                   placeholder="例）Ruby, Excel, AI活用"
                   data-category-modal-target="nameInput">
          </div>
        </div>
        <div class="cat-modal__footer">
          <button type="button" class="rs-button-primary"
                  data-action="click->category-modal#submit">追加</button>
          <button type="button" class="rs-button-ghost"
                  data-action="click->category-modal#close">キャンセル</button>
        </div>
      </div>
    </div>
  </div>

  <div class="field">
    <%= label_tag :tag_names, "タグ（カンマ区切り）" %>
    <div data-controller="tag-suggestion">
      <%= text_field_tag :tag_names,
            @log.tags&.map(&:name)&.join(", "),
            placeholder: "例) AIプロンプト, Ruby on Rails, Excel VBA",
            data: { tag_suggestion_target: "tagInput" } %>
      <%= render "logs/tag_suggestions", existing_tags: @existing_tags %>
    </div>
  </div>

  <div class="field">
    <%= f.label :body, "説明" %>
    <%= f.rich_text_area :body, placeholder: "説明を入力してください" %>
  </div>

  <div class="field">
    <%= f.label :code, "コード例" %>
    <%= f.text_area :code, rows: 10, placeholder: "ここに書いた内容は丸ごとクリップボードへコピー可能です" %>
  </div>

  <div class="field">
    <%= f.label :images, "画像（0〜5枚）" %>
    <%= f.file_field :images, multiple: true, accept: "image/*" %>
    <p class="hint paste-hint">
      ファイル選択に加えて、フォーム上で Ctrl+V / Cmd+V でスクリーンショットを画像として追加できます。
    </p>

    <% if @log.persisted? && @log.images.attached? %>
      <div class="image-strip">
        <% @log.images.each do |img| %>
          <div class="image-item">
            <%= img.blob.content_type == "image/gif" ? image_tag(url_for(img), class: "log-image-thumb") : image_tag(img.variant(resize_to_limit: [160, 120]), class: "log-image-thumb") %>
            <label class="hint">
              <%= check_box_tag "log[remove_image_ids][]", img.id %>
              この画像を削除
            </label>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="field">
    <%= f.label :memo, "ひとことメモ" %>
    <%= f.rich_text_area :memo, placeholder: "ひとことメモを入力…　例) ◯◯案件で使用。次回は△△も自動化したい。など" %>
  </div>

  <div class="actions">
    <%= f.submit(@log.persisted? ? "知識をアップデート" : "知識を記録", class: "btn-accent") %>
    <%= link_to "キャンセル", logs_path, class: "btn-subtle" %>
  </div>
<% end %>
